### Login as admin
POST http://127.0.0.1:8089/soap
Content-Type: text/xml
SOAPAction: Login

<?xml version="1.0" encoding="UTF-8"?>
<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:lab="urn:soap-dast-lab">
  <soap:Body>
    <lab:Login>
      <lab:Username>veracode</lab:Username>
      <lab:Password>veracode</lab:Password>
    </lab:Login>
  </soap:Body>
</soap:Envelope>

### Admin product list
GET http://127.0.0.1:8089/admin
Authorization: Bearer {{admin_access_token}}

### Admin product list on collection path
GET http://127.0.0.1:8089/products
Authorization: Bearer {{admin_access_token}}

### Admin create product
POST http://127.0.0.1:8089/products
Content-Type: application/xml
Authorization: Bearer {{admin_access_token}}

<?xml version="1.0" encoding="UTF-8"?>
<product>
  <sku>SKU-600</sku>
  <name>Headset Prisma ANC</name>
  <price>599.9</price>
  <stock>14</stock>
</product>

### Admin edit product with custom PUSH verb
PUSH http://127.0.0.1:8089/products
Content-Type: application/xml
Authorization: Bearer {{admin_access_token}}

<?xml version="1.0" encoding="UTF-8"?>
<product>
  <sku>SKU-100</sku>
  <price>3999.9</price>
  <stock>21</stock>
</product>

### Admin delete product
DELETE http://127.0.0.1:8089/products?sku=SKU-600
Authorization: Bearer {{admin_access_token}}

### Login as user
POST http://127.0.0.1:8089/soap
Content-Type: text/xml
SOAPAction: Login

<?xml version="1.0" encoding="UTF-8"?>
<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:lab="urn:soap-dast-lab">
  <soap:Body>
    <lab:Login>
      <lab:Username>user_apollo</lab:Username>
      <lab:Password>userpass1</lab:Password>
    </lab:Login>
  </soap:Body>
</soap:Envelope>

### User catalog
GET http://127.0.0.1:8089/user
Authorization: Bearer {{user_access_token}}

### User product list
GET http://127.0.0.1:8089/products
Authorization: Bearer {{user_access_token}}

### User should not access admin
GET http://127.0.0.1:8089/admin
Authorization: Bearer {{user_access_token}}

### User should not create products
POST http://127.0.0.1:8089/products
Content-Type: application/xml
Authorization: Bearer {{user_access_token}}

<?xml version="1.0" encoding="UTF-8"?>
<product>
  <sku>SKU-700</sku>
  <name>Blocked Product</name>
  <price>10</price>
  <stock>1</stock>
</product>

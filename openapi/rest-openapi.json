    {
      "url": "https://ca-rest-soap-labs.wonderfulcoast-2578bc9b.eastus.azurecontainerapps.io"
    }
  ],
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "stock": {
            "type": "integer"
          }
        }
      },
      "CatalogItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "stock": {
            "type": "integer"
          },
          "promotion": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ]
          }
        }
      },
      "RiskEchoRequest": {
        "type": "object",
        "properties": {
          "input": {
            "type": "string",
            "example": "<script>alert(1)</script>"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/api/products": {
      "get": {
        "summary": "List products",
        "description": "Primary product collection route for crawling and fuzzing.",
        "responses": {
          "200": {
            "description": "Product list response"
          }
        }
      },
      "post": {
        "summary": "Create product",
        "parameters": [
          {
            "name": "X-HTTP-Method-Override",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "PUSH"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Product"
              },
              "examples": {
                "sku-swg-001": {
                  "summary": "Create product SKU-SWG-001",
                  "value": {
                    "sku": "SKU-SWG-001",
                    "name": "Aurora Smart TV 55",
                    "price": 2499.9,
                    "stock": 8
                  }
                },
                "sku-swg-002": {
                  "summary": "Create product SKU-SWG-002",
                  "value": {
                    "sku": "SKU-SWG-002",
                    "name": "Boreal Notebook Pro",
                    "price": 5299.9,
                    "stock": 5
                  }
                },
                "sku-swg-003": {
                  "summary": "Create product SKU-SWG-003",
                  "value": {
                    "sku": "SKU-SWG-003",
                    "name": "Cosmos Smartphone 5G",
                    "price": 3199.9,
                    "stock": 12
                  }
                },
                "sku-swg-004": {
                  "summary": "Create product SKU-SWG-004",
                  "value": {
                    "sku": "SKU-SWG-004",
                    "name": "Delta Wireless Headset",
                    "price": 399.9,
                    "stock": 20
                  }
                },
                "sku-swg-005": {
                  "summary": "Create product SKU-SWG-005",
                  "value": {
                    "sku": "SKU-SWG-005",
                    "name": "Equinox Gaming Router",
                    "price": 899.9,
                    "stock": 7
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created"
          }
        }
      },
      "delete": {
        "summary": "Delete product by sku query parameter",

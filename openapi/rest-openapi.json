    "title": "SOAP and REST DAST Lab - Focused REST/Catalog Surface",
    "version": "1.0.0",
    "description": "Focused OpenAPI document containing /api/products, /api/products/*, /api/ecommerce, /api/ecommerce/*, /api/comments, and /api/risk* routes."

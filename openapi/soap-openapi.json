  "paths": {
    "/products": {
      "get": {
        "summary": "List products",
        "description": "Primary product collection route for crawling and fuzzing.",
        "responses": {
          "200": {
            "description": "Product list response"
          }
        }
      },
      "post": {
        "summary": "Create product",
        "parameters": [
          {
            "name": "X-HTTP-Method-Override",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "PUSH"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string"
              },
              "examples": {
                "sku-swg-001": {
                  "summary": "Create product SKU-SWG-001",
                  "value": "<product><sku>SKU-SWG-001</sku><name>Aurora Smart TV 55</name><price>2499.9</price><stock>8</stock></product>"
                },
                "sku-swg-002": {
                  "summary": "Create product SKU-SWG-002",
                  "value": "<product><sku>SKU-SWG-002</sku><name>Boreal Notebook Pro</name><price>5299.9</price><stock>5</stock></product>"
                },
                "sku-swg-003": {
                  "summary": "Create product SKU-SWG-003",
                  "value": "<product><sku>SKU-SWG-003</sku><name>Cosmos Smartphone 5G</name><price>3199.9</price><stock>12</stock></product>"
                },
                "sku-swg-004": {
                  "summary": "Create product SKU-SWG-004",
                  "value": "<product><sku>SKU-SWG-004</sku><name>Delta Wireless Headset</name><price>399.9</price><stock>20</stock></product>"
                },
                "sku-swg-005": {
                  "summary": "Create product SKU-SWG-005",
                  "value": "<product><sku>SKU-SWG-005</sku><name>Equinox Gaming Router</name><price>899.9</price><stock>7</stock></product>"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created"
          }
        }
      },
      "delete": {
        "summary": "Delete product by sku query parameter",
        "parameters": [
          {
            "name": "sku",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product deleted"
          }
        }
      },
      "patch": {
        "summary": "Update product with PATCH",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string"
              },
              "examples": {
                "sku-swg-001": {
                  "summary": "Update product price SKU-SWG-001",
                  "value": "<product><sku>SKU-SWG-001</sku><name>Aurora Smart TV 55</name><price>2299.9</price><stock>8</stock></product>"
                },
                "sku-swg-002": {
                  "summary": "Update product price SKU-SWG-002",
                  "value": "<product><sku>SKU-SWG-002</sku><name>Boreal Notebook Pro</name><price>4999.9</price><stock>5</stock></product>"
                },
                "sku-swg-003": {
                  "summary": "Update product price SKU-SWG-003",
                  "value": "<product><sku>SKU-SWG-003</sku><name>Cosmos Smartphone 5G</name><price>2899.9</price><stock>12</stock></product>"
                },
                "sku-swg-004": {
                  "summary": "Update product price SKU-SWG-004",
                  "value": "<product><sku>SKU-SWG-004</sku><name>Delta Wireless Headset</name><price>349.9</price><stock>20</stock></product>"
                },
                "sku-swg-005": {
                  "summary": "Update product price SKU-SWG-005",
                  "value": "<product><sku>SKU-SWG-005</sku><name>Equinox Gaming Router</name><price>799.9</price><stock>7</stock></product>"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product patched"
          }
        }
      },
      "put": {
        "summary": "Replace product with PUT",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string"
              },
              "example": "<product><sku>SKU-SWG-001</sku><name>Aurora Smart TV 55</name><price>2499.9</price><stock>8</stock></product>"
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product replaced"
          }
        }
      },
      "x-update": {
        "summary": "Custom HTTP UPDATE product edit",
        "description": "This route accepts the non-standard HTTP verb UPDATE with the same body used by PATCH.",
        "requestBody": {
          "example": "<product><sku>SKU-SWG-001</sku><name>Aurora Smart TV 55</name><price>2499.9</price><stock>8</stock></product>"
        },
        "responses": {
          "200": {
            "description": "Product updated by custom UPDATE verb"
          }
        }
      },
      "x-push": {
        "summary": "Custom HTTP PUSH product edit",
        "description": "This route accepts the non-standard HTTP verb PUSH with the same body used by PATCH.",
        "requestBody": {
          "example": "<product><sku>SKU-SWG-001</sku><name>Aurora Smart TV 55</name><price>2499.9</price><stock>8</stock></product>"
        },
        "responses": {
          "200": {
            "description": "Product updated by custom PUSH verb"
          }
        }
      },
      "x-accepted-verbs": [
        "GET",
        "POST",
        "PUSH",
        "PUT",
        "PATCH",
        "UPDATE",
        "DELETE",
        "HEAD",
        "OPTIONS"
      ],
      "head": {
        "summary": "HEAD metadata for /products",
        "description": "HEAD returns only response headers and no body. Use it for DAST verb discovery and metadata checks.",
        "responses": {
          "200": {
            "description": "Headers only; Content-Type is application/xml"
          },
          "404": {
            "description": "Route not found"
          }
        }
      },
      "options": {
        "summary": "OPTIONS verb discovery for /products",
        "description": "OPTIONS returns the Allow and Access-Control-Allow-Methods headers for verb discovery.",
        "responses": {
          "204": {
            "description": "Allow header lists: GET, POST, PUSH, PUT, PATCH, UPDATE, DELETE, HEAD, OPTIONS",

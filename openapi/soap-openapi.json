      "post": {
        "summary": "Submit testable comment",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "security-tester"
                  },
                  "comment": {
                    "type": "string",
                    "example": "<script>alert('xss-lab')</script>"
                  }
                }
              }
            }
          }
        },
        "responses": {
